{
  "name": "@real-estate-crm/app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate --schema ../prisma/schema.prisma && next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate --schema ../prisma/schema.prisma",
    "db:migrate": "prisma migrate deploy --schema ../prisma/schema.prisma",
