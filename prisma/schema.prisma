generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  AGENT
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  VISIT
  CLOSED
}

enum PropertyStatus {
  DRAFT
  ACTIVE
  UNDER_OFFER
  SOLD
  ARCHIVED
}

enum ActivityType {
  NOTE
  CALL
  EMAIL
  VISIT
  STATUS_CHANGE
  ASSIGNMENT
}

enum CommissionStatus {
  PENDING
  APPROVED
  PAID
}

enum MessageChannel {
  EMAIL
  WHATSAPP
  CHATBOT
  SYSTEM
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

model Company {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  settings    Json?
  users       User[]
  properties  Property[]
  leads       Lead[]
  activities  Activity[]
  commissions Commission[]
  messages    Message[]
}

model User {
  id               String       @id @default(cuid())
  companyId        String
  name             String
  email            String       @unique
  passwordHash     String
  role             Role
  phone            String?
  isActive         Boolean      @default(true)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  company          Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assignedLeads    Lead[]       @relation("LeadAssignee")
  activities       Activity[]
  commissions      Commission[]
  listedProperties Property[]   @relation("ListedBy")
  messages         Message[]

  @@index([companyId, role])
}

model Property {
  id            String         @id @default(cuid())
  companyId     String
  listedById    String?
  title         String
  description   String
  propertyType  String
  location      String
  address       String
  price         Decimal        @db.Decimal(12, 2)
  bedrooms      Int
  bathrooms     Int
  areaSqm       Float
  status        PropertyStatus @default(ACTIVE)
  referenceCode String         @unique
  imageUrls     String[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  listedBy      User?          @relation("ListedBy", fields: [listedById], references: [id], onDelete: SetNull)
  leads         Lead[]

  @@index([companyId, status])
  @@index([companyId, location])
}

model Lead {
  id               String      @id @default(cuid())
  companyId        String
  assignedToId     String?
  propertyId       String?
  fullName         String
  email            String?
  phone            String?
  source           String
  status           LeadStatus  @default(NEW)
  budget           Decimal?    @db.Decimal(12, 2)
  location         String?
  propertyType     String?
  intent           String?
  notes            String?
  aiScore          Int?
  aiClassification String?
  lastContactedAt  DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  company          Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assignedTo       User?       @relation("LeadAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  property         Property?   @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  activities       Activity[]
  commissions      Commission[]
  messages         Message[]

  @@index([companyId, status])
  @@index([companyId, assignedToId])
}

model Activity {
  id         String       @id @default(cuid())
  companyId  String
  leadId     String
  userId     String?
  type       ActivityType
  note       String
  occurredAt DateTime     @default(now())
  createdAt  DateTime     @default(now())
  company    Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead       Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user       User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId, leadId])
}

model Commission {
  id         String           @id @default(cuid())
  companyId  String
  userId     String
  leadId     String?
  amount     Decimal          @db.Decimal(12, 2)
  status     CommissionStatus @default(PENDING)
  closedAt   DateTime?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  company    Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  lead       Lead?            @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([companyId, userId])
}

model Message {
  id         String           @id @default(cuid())
  companyId  String
  leadId     String?
  userId     String?
  channel    MessageChannel
  direction  MessageDirection
  content    String
  metadata   Json?
  createdAt  DateTime         @default(now())
  company    Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead       Lead?            @relation(fields: [leadId], references: [id], onDelete: SetNull)
  user       User?            @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId, channel])
  @@index([companyId, leadId])
}

